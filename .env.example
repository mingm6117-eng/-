# Supported values: openai | deepseek | anthropic
LLM_PROVIDER=openai
LLM_API_KEY=your_provider_key_here
LLM_MODEL=gpt-4.1-mini

# Optional: override base URL for compatible APIs
# LLM_BASE_URL=

# Example models:
# OpenAI    -> gpt-4.1-mini
# DeepSeek  -> deepseek-chat
# Anthropic -> claude-sonnet-4-20250514

# Daily refresh time, using your local server timezone
DAILY_REFRESH_HOUR=7
DAILY_REFRESH_MINUTE=0
