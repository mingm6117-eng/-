# Supported values: auto | openclaw | openai | deepseek | anthropic
LLM_PROVIDER=auto
LLM_API_KEY=
LLM_MODEL=

# Optional: override base URL for compatible APIs
# LLM_BASE_URL=

# Example models:
# OpenAI    -> gpt-4.1-mini
# DeepSeek  -> deepseek-chat
# Anthropic -> claude-sonnet-4-20250514

# Optional OpenClaw fallback command.
# Use {promptFile} where the prompt file path should be inserted.
# OPENCLAW_LLM_COMMAND=openclaw infer --prompt-file {promptFile}
OPENCLAW_LLM_COMMAND=

# Daily refresh time, using your local server timezone
DAILY_REFRESH_HOUR=7
DAILY_REFRESH_MINUTE=0
