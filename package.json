{
  "name": "industry-brief-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n server,client \"node server.js\" \"vite --host 0.0.0.0\"",
    "dev:client": "vite",
    "openclaw": "bash scripts/dev-up.sh",
    "launch": "npm run openclaw",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "brief:update": "node scripts/update-industry-brief.js",
    "update": "npm run brief:update",
    "deploy:aliyun": "bash scripts/deploy-aliyun.sh"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
